# ══════════════════════════════════════════════════════════════
#  إعدادات تشغيل عدة بوتات — انسخ هذا الملف إلى .env
# ══════════════════════════════════════════════════════════════

# ── البوت الأول (مطلوب) ──────────────────────────────────────
BOT_TOKEN_1=123456789:AAF...توكن_البوت_الأول

# ── البوت الثاني (اختياري) ───────────────────────────────────
BOT_TOKEN_2=987654321:AAF...توكن_البوت_الثاني

# ── البوت الثالث (اختياري) ───────────────────────────────────
BOT_TOKEN_3=111222333:AAF...توكن_البوت_الثالث

# ── أضف المزيد بنفس النمط: BOT_TOKEN_4, BOT_TOKEN_5 ... ──────

# ── إعدادات مشتركة لجميع البوتات ─────────────────────────────
ADMIN_TELEGRAM_ID=123456789       # معرفك على تيليجرام
SESSION_SECRET=your-secret-here   # سر عشوائي

# ── نسخ احتياطي تلقائي على GitHub (اختياري) ─────────────────
GITHUB_TOKEN=ghp_...
GITHUB_REPO=hackerdarkapp-hash/srver-bot
