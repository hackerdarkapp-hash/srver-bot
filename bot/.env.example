# ══════════════════════════════════════════════════════════════
#  bot/.env.example — قالب متغيرات البيئة
#  انسخ هذا الملف إلى bot/.env وأدخل قيمك الحقيقية
#  ⚠️  لا ترفع bot/.env إلى GitHub أبداً (مضاف في .gitignore)
# ══════════════════════════════════════════════════════════════

# ── توكنات البوتات (أضف بقدر ما تحتاج من BOT_TOKEN_1 إلى BOT_TOKEN_N) ──
BOT_TOKEN_1=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
BOT_TOKEN_2=
BOT_TOKEN_3=
BOT_TOKEN_4=
BOT_TOKEN_5=
BOT_TOKEN_6=
BOT_TOKEN_7=
BOT_TOKEN_8=

# ── إعدادات الأدمن ──
ADMIN_TELEGRAM_ID=123456789

# ── مفتاح الجلسة (أي نص عشوائي طويل) ──
SESSION_SECRET=change-me-to-a-random-secret

# ── GitHub (اختياري — للميزات المرتبطة بالريبو) ──
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
GITHUB_REPO=hackerdarkapp-hash/srver-bot
